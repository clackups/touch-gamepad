# Guition ESP32-S3-4848S040 overlay (BLE only). ASCII only. See AGENTS.md.
CONFIG_TOUCH_GAMEPAD_BOARD_GUITION=y
CONFIG_TOUCH_GAMEPAD_DEFAULT_TRANSPORT_BLE=y
CONFIG_TOUCH_GAMEPAD_ENABLE_USB=n
CONFIG_TOUCH_GAMEPAD_SCREEN_WIDTH=480
CONFIG_TOUCH_GAMEPAD_SCREEN_HEIGHT=480
CONFIG_TOUCH_GAMEPAD_CORNER_MARGIN=96
CONFIG_TOUCH_GAMEPAD_DEFAULT_THEME_BLUE=y
