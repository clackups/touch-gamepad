# Waveshare ESP32-S3-Touch-LCD-4 overlay (BLE or USB). ASCII only. See AGENTS.md.
CONFIG_TOUCH_GAMEPAD_BOARD_WAVESHARE=y
CONFIG_TOUCH_GAMEPAD_DEFAULT_TRANSPORT_USB=y
CONFIG_TOUCH_GAMEPAD_ENABLE_USB=y
CONFIG_TOUCH_GAMEPAD_SCREEN_WIDTH=480
CONFIG_TOUCH_GAMEPAD_SCREEN_HEIGHT=480
CONFIG_TOUCH_GAMEPAD_CORNER_MARGIN=96
CONFIG_TOUCH_GAMEPAD_DEFAULT_THEME_BLUE=y

# TinyUSB HID interface for the USB gamepad backend.
CONFIG_TINYUSB_HID_COUNT=1
